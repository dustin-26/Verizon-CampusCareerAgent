        )

    - kind: SetVariable
      id: setVariable_MRqm4N
      variable: Topic.JobCount
      value: =CountRows(Topic.JobTable)

    - kind: ConditionGroup
      id: conditionGroup_7ZnzsX
      conditions:
        - id: conditionItem_9WzKDE
          condition: =Topic.JobCount = 0
          actions:
            - kind: SendActivity
              id: sendActivity_35Lg7i
              activity: You currently have no applications. Check for new ones?

      elseActions:
        - kind: SetMultipleVariables
          id: kYAOL2
          assignments:
            - variable: Topic.Job1
              value: =First(Topic.JobTable)

            - variable: Topic.Job2
              value: |-
                =If(
                    Topic.JobCount >= 2,
                    Index(Topic.JobTable, 2),
                    First(Topic.JobTable)
                )

            - variable: Topic.Job3
              value: |-
                =If(
                    Topic.JobCount >= 3,
                    Index(Topic.JobTable, 3),
                    First(Topic.JobTable)
                )

        - kind: SendActivity
          id: sendActivity_Hya96H
          activity:
            text:
              - Here's your application status. Good luck!
            attachments:
              - kind: AdaptiveCardTemplate
                cardContent: |-
                  ={
                      '$schema': "https://adaptivecards.io/schemas/adaptive-card.json",
                      type: "AdaptiveCard",
                      version: "1.5",

                      body: [
                          {
                              type: "TextBlock",
                              text: "Application Job",
                              weight: "Bolder",
                              size: "Large",
                              wrap: true
                          },
                          {
                              type: "TextBlock",
                              text: Concatenate(
                                  Text(Topic.JobCount),
                                  If(
                                      Topic.JobCount = 1,
                                      " recent application update",
                                      " recent application updates"
                                  )
                              ),
                              wrap: true,
                              isSubtle: true,
                              spacing: "Small"
                          },

                          {
                              type: "Container",
                              isVisible: Topic.JobCount >= 1,
                              separator: true,
                              spacing: "Medium",

                              items: [
                                  {
                                      type: "TextBlock",
                                      text: Coalesce(
                                          Topic.Job1.crcce_job1,
                                          "Untitled position"
                                      ),
                                      weight: "Bolder",
                                      size: "Medium",
                                      wrap: true
                                  },
                                  {
                                      type: "FactSet",
                                      facts: [
                                          {
                                              title: "Company",
                                              value: Coalesce(
                                                  Topic.Job1.crcce_companyname,
                                                  "Not specified"
                                              )
                                          },
                                          {
                                              title: "Applied on",
                                              value: If(
                                                  IsBlank(
                                                      Topic.Job1.crcce_appliedon
                                                  ),
                                                  "Not recorded",
                                                  Text(
                                                      Topic.Job1.crcce_appliedon,
                                                      "yyyy-mm-dd"
                                                  )
                                              )
                                          },
                                          {
                                              title: "Status",
                                              value: Coalesce(
                                                  Topic.Job1.crcce_applicationstatus,
                                                  "Not specified"
                                              )
                                          }
                                      ]
                                  }
                              ]
                          },

